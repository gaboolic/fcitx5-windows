 AddonInstance *LuaAddonLoader::load(const AddonInfo &info,
                                     AddonManager *manager) {
+    FCITX_LUA_FORCE_TRACE("LuaAddonLoader load begin addon=" << info.uniqueName()
+                          << " library=" << info.library());
 #ifdef USE_DLOPEN
     if (!luaLibrary_->loaded()) {
+        FCITX_LUA_FORCE_TRACE(
+            "LuaAddonLoader load aborted: lua library not loaded");
         return nullptr;
     }
 #endif
+    FCITX_LUA_FORCE_TRACE("LuaAddonLoader load category addon="
+                          << info.uniqueName() << " category="
+                          << static_cast<int>(info.category()));
     if (info.category() == AddonCategory::Module) {
         try {
+            FCITX_LUA_FORCE_TRACE(
+                "LuaAddonLoader constructing LuaAddon addon="
+                << info.uniqueName());
             auto addon =
                 std::make_unique<LuaAddon>(luaLibrary_.get(), info, manager);
+            FCITX_LUA_FORCE_TRACE("LuaAddonLoader load success addon="
+                                  << info.uniqueName());
             return addon.release();
         } catch (const std::exception &e) {
+            FCITX_LUA_FORCE_TRACE("LuaAddonLoader load failed addon="
+                                  << info.uniqueName()
+                                  << " error=" << e.what());
             FCITX_LUA_ERROR() << "Loading lua addon " << info.uniqueName()
                               << " failed: " << e.what();
             return nullptr;
         }
     }
+    FCITX_LUA_FORCE_TRACE("LuaAddonLoader load returning nullptr addon="
+                          << info.uniqueName() << " category="
+                          << static_cast<int>(info.category()));
     return nullptr;
 }
