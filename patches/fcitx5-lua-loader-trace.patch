 #include "luahelper.h"
 #include "luaaddonstate.h"
+#include <cstdio>
+#include <cstdlib>
 #include <fcitx-utils/log.h>
+#ifdef _WIN32
+#include <windows.h>
+#endif
 
 namespace fcitx {
 
 FCITX_DEFINE_LOG_CATEGORY(lua_log, "lua");
 
 decltype(&::lua_getglobal) _fcitx_lua_getglobal;
 decltype(&::lua_touserdata) _fcitx_lua_touserdata;
 decltype(&::lua_settop) _fcitx_lua_settop;
 decltype(&::lua_close) _fcitx_lua_close;
 decltype(&::luaL_newstate) _fcitx_luaL_newstate;
+
+namespace {
+
+std::string luaTraceLogPath() {
+#ifdef _WIN32
+    if (const char *temp = std::getenv("TEMP"); temp && *temp) {
+        std::string path(temp);
+        if (path.back() != '\\' && path.back() != '/') {
+            path += '\\';
+        }
+        path += "fcitx5-lua-loader-trace.log";
+        return path;
+    }
+#endif
+    return "fcitx5-lua-loader-trace.log";
+}
+
+} // namespace
+
+void LuaForceTrace(const std::string &msg) {
+    FCITX_LUA_ERROR() << msg;
+#ifdef _WIN32
+    std::string line = "[fcitx5-lua] " + msg + "\r\n";
+    OutputDebugStringA(line.c_str());
+#else
+    std::string line = "[fcitx5-lua] " + msg + "\n";
+    std::fputs(line.c_str(), stderr);
+#endif
+    const auto path = luaTraceLogPath();
+    if (FILE *fp = std::fopen(path.c_str(), "ab")) {
+        std::fwrite(line.data(), 1, line.size(), fp);
+        std::fclose(fp);
+    }
+}
 
