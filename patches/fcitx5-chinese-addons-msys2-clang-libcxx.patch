diff --git a/tools/scel2org5.cpp b/tools/scel2org5.cpp
--- a/tools/scel2org5.cpp
+++ b/tools/scel2org5.cpp
@@ -44,6 +44,10 @@
 #include <libkern/OSByteOrder.h>
 #define le16toh(x) OSSwapLittleToHostInt16(x)
 #define le32toh(x) OSSwapLittleToHostInt32(x)
+#elif defined(_WIN32) || defined(__CYGWIN__)
+// Windows targets are little-endian; SCEL uses little-endian words.
+#define le16toh(x) (static_cast<uint16_t>(x))
+#define le32toh(x) (static_cast<uint32_t>(x))
 #else
 #include <sys/endian.h>
 #endif
