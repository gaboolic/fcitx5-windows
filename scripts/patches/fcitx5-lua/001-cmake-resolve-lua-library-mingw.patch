diff --git a/CMakeLists.txt b/CMakeLists.txt
index 353d592..38c6446 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -74,8 +74,12 @@ function(_RESOLVE_LIBRARY_PATH _FILE_NAME _LIBRARY_PATH)
             ERROR_QUIET
         )
         string(REGEX REPLACE ".*SONAME +([^ ]+)\n.*$" "\\1" SONAME_OUT "${OBJDUMP_RESULT}")
-        if (SONAME_OUT)
+        # ELF SONAME; MinGW import libs (.dll.a) have no SONAME — REGEX REPLACE leaves
+        # SONAME_OUT equal to the full objdump text. Do not embed that into config.h.
+        if (SONAME_OUT AND NOT SONAME_OUT STREQUAL OBJDUMP_RESULT)
             set(_FILE_NAME_OUT "${SONAME_OUT}")
+        elseif (OBJDUMP_RESULT MATCHES "[(]([a-zA-Z0-9._-]+\\.dll)[)]")
+            string(REGEX REPLACE ".*[(]([a-zA-Z0-9._-]+\\.dll)[)].*" "\\1" _FILE_NAME_OUT "${OBJDUMP_RESULT}")
         endif ()
     endif()
     if (NOT _FILE_NAME_OUT)
