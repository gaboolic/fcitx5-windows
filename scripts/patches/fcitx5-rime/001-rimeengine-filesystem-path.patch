+/// Narrow UTF-8 path for fcitx::fs APIs and librime (const char *). On Windows,
+/// std::filesystem::path uses wchar_t; path::c_str() is not usable as UTF-8.
+inline std::string rimePathToUtf8(const std::filesystem::path &p) {
+#ifdef _WIN32
+    const auto &native = p.native();
+    if (native.empty()) {
+        return {};
+    }
+    int n = WideCharToMultiByte(CP_UTF8, 0, native.c_str(), -1, nullptr, 0,
+                                nullptr, nullptr);
+    if (n <= 0) {
+        return {};
+    }
+    std::string s(static_cast<size_t>(n - 1), '\0');
+    WideCharToMultiByte(CP_UTF8, 0, native.c_str(), -1, s.data(), n, nullptr,
+                        nullptr);
+    return s;
+#else
+    auto u8 = p.u8string();
+    return {reinterpret_cast<const char *>(u8.data()), u8.size()};
+#endif
+}
