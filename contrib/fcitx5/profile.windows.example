# Windows 安装程序默认种子（Inno Setup → %AppData%\Fcitx5\config\fcitx5\profile）
# 托盘「切换输入法」只显示本分组下列出的 Name=，与 fcitx5-config / Linux 版行为一致。
# - pinyin：需 libpinyin.dll（libime + chinese-addons）
# - wbx：五笔字形，需 libtable.dll 与词库（同上）；Name 必须与 share/fcitx5/inputmethod/wbx.conf 对应项一致
# 未安装 keyboard 引擎时勿加 keyboard-us（见 profile.pinyin.example / PINYIN_WINDOWS.md）
# 中州韵（rime）需单独安装 fcitx5-rime 及数据，当前官方安装包未附带；勿在此写 rime 除非已部署对应 addon

[Groups/0]
Name=Default
Default Layout=us
DefaultIM=pinyin

[Groups/0/Items/0]
Name=pinyin
Layout=

[Groups/0/Items/1]
Name=wbx
Layout=

[GroupOrder]
0=Default
